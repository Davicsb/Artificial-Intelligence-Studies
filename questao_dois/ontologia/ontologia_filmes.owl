<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://test.org/filmes.owl"
         xmlns="http://test.org/filmes.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://test.org/filmes.owl"/>

<owl:ObjectProperty rdf:about="#temGenero">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="#Genero"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#atuouEm">
  <rdfs:domain rdf:resource="#Ator"/>
  <rdfs:range rdf:resource="#Filme"/>
  <owl:inverseOf rdf:resource="#temAtor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#temAtor">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="#Ator"/>
  <owl:inverseOf rdf:resource="#atuouEm"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#dirigiu">
  <rdfs:domain rdf:resource="#Diretor"/>
  <rdfs:range rdf:resource="#Filme"/>
  <owl:inverseOf rdf:resource="#temDiretor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#temDiretor">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="#Diretor"/>
  <owl:inverseOf rdf:resource="#dirigiu"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#gostaDeGenero">
  <rdfs:domain rdf:resource="#Usuario"/>
  <rdfs:range rdf:resource="#Genero"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#gostaDeAtor">
  <rdfs:domain rdf:resource="#Usuario"/>
  <rdfs:range rdf:resource="#Ator"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#assistiu">
  <rdfs:domain rdf:resource="#Usuario"/>
  <rdfs:range rdf:resource="#Filme"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#recomendadoPara">
  <rdfs:domain rdf:resource="#Usuario"/>
  <rdfs:range rdf:resource="#Filme"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#titulo">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#anoLancamento">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#notaIMDB">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#duracaoMinutos">
  <rdfs:domain rdf:resource="#Filme"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#nomeUsuario">
  <rdfs:domain rdf:resource="#Usuario"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#idadeUsuario">
  <rdfs:domain rdf:resource="#Usuario"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Genero">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Pessoa">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Ator">
  <rdfs:subClassOf rdf:resource="#Pessoa"/>
</owl:Class>

<owl:Class rdf:about="#Diretor">
  <rdfs:subClassOf rdf:resource="#Pessoa"/>
</owl:Class>

<owl:Class rdf:about="#Usuario">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Filme">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#FilmeAcao">
  <rdfs:subClassOf rdf:resource="#Filme"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Filme"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#temGenero"/>
          <owl:someValuesFrom rdf:resource="#Acao"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#FilmeFiccao">
  <rdfs:subClassOf rdf:resource="#Filme"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Filme"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#temGenero"/>
          <owl:someValuesFrom rdf:resource="#FiccaoCientifica"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#FilmeDrama">
  <rdfs:subClassOf rdf:resource="#Filme"/>
</owl:Class>

<owl:Class rdf:about="#FilmeComedia">
  <rdfs:subClassOf rdf:resource="#Filme"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Acao">
  <rdf:type rdf:resource="#Genero"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#FiccaoCientifica">
  <rdf:type rdf:resource="#Genero"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Drama">
  <rdf:type rdf:resource="#Genero"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Keanu_Reeves">
  <rdf:type rdf:resource="#Ator"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Leonardo_DiCaprio">
  <rdf:type rdf:resource="#Ator"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Christopher_Nolan">
  <rdf:type rdf:resource="#Diretor"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Lana_Wachowski">
  <rdf:type rdf:resource="#Diretor"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#The_Matrix">
  <rdf:type rdf:resource="#Filme"/>
  <temGenero rdf:resource="#Acao"/>
  <temGenero rdf:resource="#FiccaoCientifica"/>
  <temAtor rdf:resource="#Keanu_Reeves"/>
  <temDiretor rdf:resource="#Lana_Wachowski"/>
  <titulo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Matrix</titulo>
  <anoLancamento rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1999</anoLancamento>
  <notaIMDB rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.7</notaIMDB>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Inception">
  <rdf:type rdf:resource="#Filme"/>
  <temGenero rdf:resource="#FiccaoCientifica"/>
  <temGenero rdf:resource="#Acao"/>
  <temAtor rdf:resource="#Leonardo_DiCaprio"/>
  <temDiretor rdf:resource="#Christopher_Nolan"/>
  <titulo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A Origem</titulo>
  <anoLancamento rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2010</anoLancamento>
  <notaIMDB rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.8</notaIMDB>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Interstellar">
  <rdf:type rdf:resource="#Filme"/>
  <temGenero rdf:resource="#FiccaoCientifica"/>
  <temGenero rdf:resource="#Drama"/>
  <temDiretor rdf:resource="#Christopher_Nolan"/>
  <titulo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interestelar</titulo>
  <anoLancamento rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2014</anoLancamento>
  <notaIMDB rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.6</notaIMDB>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#John_Wick">
  <rdf:type rdf:resource="#Filme"/>
  <temGenero rdf:resource="#Acao"/>
  <temAtor rdf:resource="#Keanu_Reeves"/>
  <titulo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">De Volta ao Jogo</titulo>
  <anoLancamento rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2014</anoLancamento>
  <notaIMDB rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.4</notaIMDB>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Joao_Silva">
  <rdf:type rdf:resource="#Usuario"/>
  <gostaDeGenero rdf:resource="#FiccaoCientifica"/>
  <gostaDeAtor rdf:resource="#Keanu_Reeves"/>
  <recomendadoPara rdf:resource="#Interstellar"/>
  <recomendadoPara rdf:resource="#The_Matrix"/>
  <recomendadoPara rdf:resource="#John_Wick"/>
  <recomendadoPara rdf:resource="#Inception"/>
  <nomeUsuario rdf:datatype="http://www.w3.org/2001/XMLSchema#string">João da Silva</nomeUsuario>
  <idadeUsuario rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">25</idadeUsuario>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#u"/>

<swrl:Variable rdf:about="urn:swrl#f"/>

<swrl:Variable rdf:about="urn:swrl#g"/>

<swrl:Variable rdf:about="urn:swrl#a"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Usuario"/>
          <swrl:argument1 rdf:resource="urn:swrl#u"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:ClassAtom>
              <swrl:classPredicate rdf:resource="#Filme"/>
              <swrl:argument1 rdf:resource="urn:swrl#f"/>
            </swrl:ClassAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#gostaDeAtor"/>
                  <swrl:argument1 rdf:resource="urn:swrl#u"/>
                  <swrl:argument2 rdf:resource="urn:swrl#a"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#temAtor"/>
                      <swrl:argument1 rdf:resource="urn:swrl#f"/>
                      <swrl:argument2 rdf:resource="urn:swrl#a"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#recomendadoPara"/>
          <swrl:argument1 rdf:resource="urn:swrl#u"/>
          <swrl:argument2 rdf:resource="urn:swrl#f"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Usuario"/>
          <swrl:argument1 rdf:resource="urn:swrl#u"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:ClassAtom>
              <swrl:classPredicate rdf:resource="#Filme"/>
              <swrl:argument1 rdf:resource="urn:swrl#f"/>
            </swrl:ClassAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#gostaDeGenero"/>
                  <swrl:argument1 rdf:resource="urn:swrl#u"/>
                  <swrl:argument2 rdf:resource="urn:swrl#g"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#temGenero"/>
                      <swrl:argument1 rdf:resource="urn:swrl#f"/>
                      <swrl:argument2 rdf:resource="urn:swrl#g"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#recomendadoPara"/>
          <swrl:argument1 rdf:resource="urn:swrl#u"/>
          <swrl:argument2 rdf:resource="urn:swrl#f"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
